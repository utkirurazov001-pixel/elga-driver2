{
  "expo": {
    "name": "ELGA Mijoz",
    "slug": "elga-mijoz",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "url": "https://u.expo.dev/e5561b58-380f-45f6-9cc4-c6af58eaec84",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.elga.mijoz",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ELGA taksini chaqirish uchun joylashuvingizdan foydalanadi.",
        "NSMicrophoneUsageDescription": "Ovozli buyurtma berish uchun mikrofondan foydalanadi."
      }
    },
    "android": {
      "package": "uz.elga.mijoz",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ELGA taksini chaqirish uchun joylashuvingizdan foydalanadi."
        }
      ],
      "expo-notifications",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "e5561b58-380f-45f6-9cc4-c6af58eaec84"
      }
    }
  }
}
